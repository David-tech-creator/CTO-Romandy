// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ClientReference {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Core fields
  clientName        String
  isAnonymized      Boolean  @default(false)
  industry          String
  projectTitle      String
  startDate         DateTime?
  endDate           DateTime?
  location          String
  
  // Service details
  servicesDescription String @db.Text
  technologies        String @db.Text
  methodologies       String @db.Text
  
  // Team information
  teamSize           Int?
  teamRoles          String @db.Text
  
  // Impact and results
  valueDelivered     String @db.Text
  impact             String @db.Text
  
  // Optional contact and reference
  clientContactName  String?
  clientContactRole  String?
  clientContactInfo  String?
  referenceLetter    String? @db.Text
  
  // Raw text for reference
  rawText           String? @db.Text
  
  // Search optimization
  searchVector      Unsupported("tsvector")?
  
  @@map("client_references")
  @@index([industry])
  @@index([projectTitle])
  @@index([clientName])
}

model ProcessingJob {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  status      String   // 'pending', 'processing', 'completed', 'failed'
  rawText     String   @db.Text
  result      Json?
  error       String?  @db.Text
  
  @@map("processing_jobs")
} 